<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About us 完全再現テスト</title>

    <style>
        /* 1. Google Fontsからおしゃれな手書きフォントを読み込む */
        @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@700&display=swap');
        
        /* 2. 日本語用のフォント（明朝体）を読み込む */
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300&display=swap');

        /* 画面全体の基本設定（参考サイトのような優しい背景色にしています） */
        body {
            background-color: #fcfbfa;
            font-family: sans-serif;
            margin: 0;
            padding: 50px;
        }

        /* セクション全体の囲み（左側に薄いオレンジの背景を配置） */
        .about-section {
            position: relative;
            padding-left: 40px;
            /* 参考サイトの左側にある薄いオレンジの装飾を再現 */
            background: linear-gradient(to right, #fdf5e6 25px, transparent 25px);
        }

        /* 【完全再現】英語の見出し（About us） */
        .about-title-en {
            /* フォントを最優先で手書き風（Caveat）に指定 */
            font-family: 'Caveat', cursive !important; 
            font-size: 5.5rem !important; /* 文字の大きさ */
            font-weight: 700 !important;  /* 太字 */
            margin: 0 !important;
            padding: 0 !important;
            display: inline-block !important;
            line-height: 1.0 !important;
            letter-spacing: 0.02em !important;

            /* 上から下への鮮やかな黄色〜オレンジのグラデーション */
            background: linear-gradient(to bottom, #fcee21 0%, #f1b83a 100%) !important;
            -webkit-background-clip: text !important;
            background-clip: text !important;
            -webkit-text-fill-color: transparent !important;
            color: transparent !important;
            .about-title-en {
    font-family: 'Caveat', cursive !important; 
    font-size: 5.5rem !important;
    font-weight: 700 !important;
    margin: 0 !important;
    padding: 0 !important;
    display: inline-block !important;
    line-height: 1.0 !important;
    letter-spacing: 0.02em !important;

    /* グラデーション設定 */
    background: linear-gradient(to bottom, #fcee21 0%, #f1b83a 100%) !important;
    -webkit-background-clip: text !important;
    background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    color: transparent !important;

    /* 👇【文字切れ対策】ここから下の3行を追加・修正してください */
    padding-right: 0.15em !important; /* 右側に文字がはみ出るための余白を作る */
    margin-right: -0.15em !important;  /* 余白を作った分、全体の枠を元の位置に戻す */
    width: auto !important;
}
        }

        /* 【完全再現】日本語のサブタイトル（私たちについて） */
        .about-title-ja {
            display: block !important;
            font-family: 'Noto Serif JP', serif !important; /* 上品な明朝体 */
            font-size: 1rem !important;
            color: #666666 !important; /* 少し薄めの洗練されたグレー */
            margin-top: -5px !important; /* 英語の文字との隙間を狭くする */
            letter-spacing: 0.1em !important;
        }
    </style>
</head>

    <body>

    <h2 class="about-title-en">About us</h2>

</body>
</html>